# ============================================================
# Shopify Hydrogen — Environment Variables
# ============================================================
# Dokuman: https://shopify.dev/docs/storefronts/headless/hydrogen/environment-variables
# Oxygen production'da Shopify admin'deki variable manager kullanilir.

# --- Storefront API (public — client-safe) ---
PUBLIC_STORE_DOMAIN="your-store.myshopify.com"
PUBLIC_STOREFRONT_API_TOKEN="shpsa_xxxxxxxxxxxxxxxxxxxxxx"
PUBLIC_STOREFRONT_ID="1234567890"
PUBLIC_STOREFRONT_API_VERSION="2024-10"

# --- Private Storefront Token (server-only — delegate access) ---
PRIVATE_STOREFRONT_API_TOKEN="shpat_xxxxxxxxxxxxxxxxxxxxxx"

# --- Shopify Customer Account API ---
PUBLIC_CUSTOMER_ACCOUNT_API_URL="https://shopify.com/1234567890"
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID="shp_xxxxx"

# --- Checkout domain (fallback cart) ---
PUBLIC_CHECKOUT_DOMAIN="checkout.your-store.com"

# --- Session secret ---
SESSION_SECRET="random-32-char-secret-generate-with-openssl"

# --- Turkiye Payment (iyzipay Shopify 3rd party app) ---
# Shopify admin'den iyzipay Shopify app kurulur, bu env'ler app setup'ta.
# Bilgi: https://apps.shopify.com/iyzico-turkey
IYZIPAY_API_KEY="your-iyzipay-api-key"
IYZIPAY_SECRET_KEY="your-iyzipay-secret"
IYZIPAY_BASE_URL="https://api.iyzipay.com"

# --- PayTR alternatif (2. payment gateway) ---
PAYTR_MERCHANT_ID=""
PAYTR_MERCHANT_KEY=""
PAYTR_MERCHANT_SALT=""

# --- 3D Asset CDN (Cloudflare R2 veya Shopify CDN) ---
# Shopify Metafield "custom.3d_model_url" genellikle Shopify Files URL'si veya
# Cloudflare R2 signed URL. Static CDN icin:
PUBLIC_3D_ASSET_CDN="https://cdn.your-store.com/3d-models"

# --- Analytics ---
PUBLIC_SHOPIFY_ANALYTICS="true"
PUBLIC_GA4_MEASUREMENT_ID=""
