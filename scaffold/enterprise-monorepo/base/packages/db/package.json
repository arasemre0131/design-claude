{
  "name": "@preset/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema + migrations + tenant-scoped queries",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./queries": "./src/queries.ts"
  },
  "scripts": {
