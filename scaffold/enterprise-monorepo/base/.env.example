# ================================================================
#  __PRESET_ID__ — Enterprise Monorepo (Tier 5)
#  Bu dosyayi .env.local olarak kopyala ve degerleri doldur.
#  ASLA .env.local'i commit etme (.gitignore'a ekli).
# ================================================================

# ---- Genel ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=yourapp.com

# ---- Supabase (Postgres + Auth + Storage) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...          # ASLA client bundle'a
DATABASE_URL=postgresql://postgres:password@localhost:5432/preset_dev

# ---- Redis (session + rate limit + cache) ----
REDIS_URL=redis://localhost:6379

# ---- Observability ----
# Sentry (error tracking + performance + session replay)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ORG=preset-org
SENTRY_PROJECT=preset-web
SENTRY_AUTH_TOKEN=sntrys_xxxxx                             # source map upload icin

# Mixpanel (event analytics)
NEXT_PUBLIC_MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxx

# PostHog (session replay + feature flags + product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---- Payment ----
# iyzico (Turkiye)
IYZICO_API_KEY=sandbox-xxx
IYZICO_SECRET_KEY=sandbox-xxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Stripe (uluslararasi)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ---- Email (Resend + react-email) ----
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=no-reply@yourapp.com

# ---- Background jobs (opsiyonel) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---- Cloudflare (R2 + turnstile) ----
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=preset-assets
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Multi-tenant ----
ROOT_DOMAIN=yourapp.com                                    # Ana domain (subdomain rewrites icin)
ADMIN_DOMAIN=admin.yourapp.com                             # Admin panel subdomain
API_DOMAIN=api.yourapp.com                                 # API subdomain

# ---- CI/CD (sadece production) ----
VERCEL_TOKEN=
FLY_API_TOKEN=
